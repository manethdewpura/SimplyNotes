<Window x:Class="StickyNotes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sticky Note"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        MinWidth="200" MinHeight="180"
        Width="280"   Height="320"
        Topmost="False"
        SizeToContent="Manual">

    <!-- ══════════════════════════════════════════════════════════════
         Root border — gives the note its rounded shape and drop-shadow
    ═══════════════════════════════════════════════════════════════════ -->
    <Border x:Name="RootBorder"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#20000000">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="4"
                              Direction="270"
                              Color="#000000"
                              Opacity="0.18" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="36" />
                <!-- Body (text area grows to fill) -->
                <RowDefinition Height="*" />
                <!-- Topic bar -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 ROW 0 — Draggable header
            ═══════════════════════════════════════════════════════════ -->
            <Border x:Name="HeaderBorder"
                    Grid.Row="0"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Cursor="SizeAll">

                <Grid Margin="6,0,4,0">
                    <Grid.ColumnDefinitions>
                        <!-- Buttons on the left -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Drag handle (transparent, grabs mouse) -->
                        <ColumnDefinition Width="*" />
                        <!-- Delete button on the right -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left button group -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- New Note (+) -->
                        <Button x:Name="BtnNewNote"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="New Note"
                                Click="BtnNewNote_Click"
                                AutomationProperties.Name="New Note">
                            <TextBlock Text="+" FontSize="17" FontWeight="Light" Margin="0,-1,0,0"/>
                        </Button>

                        <!-- Pin (Always on top) -->
                        <ToggleButton x:Name="BtnPin"
                                      Style="{StaticResource HeaderToggleButtonStyle}"
                                      ToolTip="Pin (Always on Top)"
                                      Checked="BtnPin_Checked"
                                      Unchecked="BtnPin_Unchecked"
                                      AutomationProperties.Name="Pin Note">
                            <TextBlock Text="📌" FontSize="13" Margin="0,0,0,0"/>
                        </ToggleButton>

                        <!-- Checklist Mode -->
                        <ToggleButton x:Name="BtnChecklist"
                                      Style="{StaticResource HeaderToggleButtonStyle}"
                                      ToolTip="Toggle Checklist Mode"
                                      Checked="BtnChecklist_Checked"
                                      Unchecked="BtnChecklist_Unchecked"
                                      AutomationProperties.Name="Toggle Checklist">
                            <TextBlock Text="☑" FontSize="14" Margin="0,0,0,0"/>
                        </ToggleButton>

                        <!-- Colour Palette -->
                        <Button x:Name="BtnColorPicker"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="Change Color"
                                Click="BtnColorPicker_Click"
                                AutomationProperties.Name="Change Color">
                            <!-- Palette icon drawn with three overlapping ellipses -->
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="0" Canvas.Top="2"
                                         Width="10" Height="10"
                                         Fill="#FDE047" Stroke="#9CA3AF" StrokeThickness="1"/>
                                <Ellipse Canvas.Left="6" Canvas.Top="5"
                                         Width="10" Height="10"
                                         Fill="#93C5FD" Stroke="#9CA3AF" StrokeThickness="1"/>
                                <Ellipse Canvas.Left="3" Canvas.Top="6"
                                         Width="10" Height="10"
                                         Fill="#86EFAC" Stroke="#9CA3AF" StrokeThickness="1"/>
                            </Canvas>
                        </Button>

                        <!-- Divider -->
                        <Border Width="1" Height="14" Background="#D1D5DB" Margin="4,0,6,0"/>

                        <!-- Formatting Toolbar -->
                        <ToggleButton Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=NoteRichTextBox}" ToolTip="Bold" Style="{StaticResource FormatToggleButtonStyle}">
                            <TextBlock Text="B" />
                        </ToggleButton>
                        <ToggleButton Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=NoteRichTextBox}" ToolTip="Italic" Style="{StaticResource FormatToggleButtonStyle}">
                            <TextBlock Text="I" FontStyle="Italic"/>
                        </ToggleButton>
                        <ToggleButton x:Name="BtnStrikethrough" Click="BtnStrikethrough_Click" ToolTip="Strikethrough" Style="{StaticResource FormatToggleButtonStyle}">
                            <TextBlock Text="S" TextDecorations="Strikethrough"/>
                        </ToggleButton>
                        <ToggleButton Command="EditingCommands.ToggleBullets" CommandTarget="{Binding ElementName=NoteRichTextBox}" ToolTip="Bullet List" Style="{StaticResource FormatToggleButtonStyle}">
                            <TextBlock Text="•" FontSize="16" Margin="0,-4,0,0"/>
                        </ToggleButton>

                    </StackPanel>

                    <!-- Centre drag zone -->
                    <Border Grid.Column="1"
                            Background="Transparent"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown"
                            Cursor="SizeAll" />

                    <!-- Delete (X) -->
                    <Button x:Name="BtnDelete"
                            Grid.Column="2"
                            Style="{StaticResource HeaderButtonStyle}"
                            ToolTip="Delete Note"
                            Click="BtnDelete_Click"
                            AutomationProperties.Name="Delete Note"
                            Foreground="#EF4444">
                        <TextBlock Text="✕" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ROW 1 — Note body (RichTextBox OR Checklist)
            ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <!-- Text Mode -->
                <RichTextBox x:Name="NoteRichTextBox"
                             Style="{StaticResource NoteRichTextBoxStyle}"
                             TextChanged="NoteRichTextBox_TextChanged"
                             SpellCheck.IsEnabled="True"
                             Language="en-US">
                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Cut"   Command="ApplicationCommands.Cut"   />
                            <MenuItem Header="Copy"  Command="ApplicationCommands.Copy"  />
                            <MenuItem Header="Paste" Command="ApplicationCommands.Paste" />
                            <Separator />
                            <MenuItem x:Name="ContextColorMenu" Header="Change Color" />
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>

                <!-- Checklist Mode -->
                <ScrollViewer x:Name="ChecklistScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,5,12,10">
                        <ItemsControl x:Name="ChecklistItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                  VerticalAlignment="Center" 
                                                  Margin="0,0,8,0"
                                                  Checked="TodoCheckBox_Checked"
                                                  Unchecked="TodoCheckBox_Checked" />

                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 TextWrapping="Wrap"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontSize="13.5"
                                                 FontFamily="Segoe UI"
                                                 Foreground="#374151"
                                                 VerticalAlignment="Center"
                                                 TextChanged="TodoTextBox_TextChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            <Setter Property="Foreground" Value="#9CA3AF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        
                                        <!-- Delete Item Button -->
                                        <Button Grid.Column="2"
                                                Click="BtnDeleteTodo_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#9CA3AF"
                                                Cursor="Hand"
                                                ToolTip="Delete Item"
                                                Content="✕"
                                                FontSize="10"
                                                VerticalAlignment="Center"
                                                Margin="4,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add new item row -->
                        <Button x:Name="BtnAddTodo" 
                                Click="BtnAddTodo_Click"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#6B7280"
                                FontSize="13.5"
                                FontFamily="Segoe UI"
                                Margin="22,6,0,0"
                                Cursor="Hand">
                            <TextBlock Text="+ List item" FontStyle="Italic"/>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 2 — Topic bar  (label / edit overlay)
            ═══════════════════════════════════════════════════════════ -->

            <!-- Read-only label (double-click to edit) -->
            <Border x:Name="TopicBorder"
                    Grid.Row="2"
                    CornerRadius="0,0,10,10"
                    Padding="10,5">
                <TextBlock x:Name="TopicLabel"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontStyle="Italic"
                           Foreground="#6B7280"
                           Text="Double-click to set topic…"
                           Cursor="IBeam"
                           MouseLeftButtonDown="TopicLabel_MouseLeftButtonDown"
                           ToolTip="Double-click to edit topic" />
            </Border>

            <!-- Editable TextBox (shown only while editing; overlays TopicBorder) -->
            <Border x:Name="TopicEditorBorder"
                    Grid.Row="2"
                    CornerRadius="0,0,10,10"
                    Padding="8,4"
                    Background="Transparent"
                    Visibility="Collapsed">
                <TextBox x:Name="TopicTextBox"
                         FontFamily="Segoe UI"
                         FontSize="13"
                         FontStyle="Italic"
                         Foreground="#374151"
                         Background="Transparent"
                         BorderThickness="0,0,0,1"
                         BorderBrush="#9CA3AF"
                         MaxLength="60"
                         FocusVisualStyle="{x:Null}"
                         LostFocus="TopicTextBox_LostFocus"
                         KeyDown="TopicTextBox_KeyDown" />
            </Border>

        </Grid>
    </Border>
</Window>
