# ──────────────────────────────────────────────
#  .gitignore — SimplyNotes (C# WPF / .NET 8)
# ──────────────────────────────────────────────

# ── Build output ──────────────────────────────
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# ── .NET / MSBuild ────────────────────────────
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
nuget.config

# Publish output
publish/
PublishProfiles/

# ── Visual Studio ─────────────────────────────
.vs/
*.rsuser
*.vsp
*.vspx
*.sap
*.userprefs

# ReSharper / Rider
.idea/
_ReSharper*/
*.DotSettings.user

# ── OS artefacts ──────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS (if ever opened on Mac)
.DS_Store
.AppleDouble
.LSOverride

# ── Editor / tooling ──────────────────────────
*.swp
*.swo
*~
.vscode/
*.code-workspace

# ── Test results ──────────────────────────────
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*/

# ── Runtime / user data ───────────────────────
# Don't commit the user's own saved notes
notes.json
installer.iss
/Output/*
.env